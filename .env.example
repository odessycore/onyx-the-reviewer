# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database ---
# Docker compose maps host 5433 -> container 5432 (avoids a local Postgres on 5432).
DATABASE_URL=postgresql://reviewer:reviewer@localhost:5433/ai_pr_reviewer

# --- Encryption (32-byte key, base64 or hex). Used to encrypt stored LLM API keys. ---
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=

# --- GitHub App ---
GITHUB_APP_ID=
# The app's slug (from its public page URL). Used for @mentions and to ignore the bot's own comments.
GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=
# Paste the PEM contents with literal \n escapes, or point GITHUB_PRIVATE_KEY_PATH at the file.
GITHUB_PRIVATE_KEY=
GITHUB_PRIVATE_KEY_PATH=

# --- Default LLM (chat) provider. Per-installation settings override these. ---
# Supported providers: anthropic | openai-compatible
# openai-compatible targets any /chat/completions endpoint (OpenAI, HF router, vLLM, Ollama...).
LLM_PROVIDER=anthropic
LLM_BASE_URL=
LLM_MODEL=claude-opus-4-8
LLM_API_KEY=

# --- Default embedding provider (OpenAI-compatible /embeddings; works with HF TGI / local). ---
# EMBEDDING_DIMENSIONS must match the vector(N) column in prisma/schema.prisma.
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_DIMENSIONS=384

# --- Job worker ---
WORKER_ENABLED=true
WORKER_POLL_INTERVAL_MS=2000
WORKER_BATCH_SIZE=5
# Jobs left 'running' longer than this (e.g. after a worker crash) are reclaimed for retry.
WORKER_STUCK_JOB_TIMEOUT_MS=300000
JOB_MAX_ATTEMPTS=5
JOB_BACKOFF_BASE_MS=2000
JOB_BACKOFF_CAP_MS=300000
